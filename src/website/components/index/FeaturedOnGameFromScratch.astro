---
/**
  * FeaturedOnGameFromScratch
  */
---

<section class="press-coverage-section" aria-label="Press coverage">
    <div class="gfs-card">
        <header class="gfs-header">
            <span aria-hidden="true">⭐️</span>

            <div class="gfs-text">
                <h3>Featured on GameFromScratch</h3>
                <p>A full tutorial video and write-up</p>
            </div>
        </header>

        <nav class="gfs-actions">
            <a
                    href="https://youtu.be/YW5N8ANrm9c?si=cr1RFxQvIf4vPdPf"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="button medium"
            >
                ▶ Watch the video
            </a>

            <a
                    href="https://gamefromscratch.com/folded-paper-engine-blender-to-godot"
                    target="_blank"
                    rel="noopener noreferrer"
                    class="button medium"
            >
                📝 Read the article
            </a>
        </nav>
    </div>
</section>

<style>
    .press-coverage-section {
        background:
                radial-gradient(circle at 14% 20%, rgba(255, 255, 255, 0.38), transparent 18rem),
                linear-gradient(135deg, rgba(255, 193, 0, 0.95), rgba(255, 244, 206, 0.92) 48%, rgba(120, 168, 194, 0.56)),
                #ffc100;
        margin: 0 0 0 0;
        padding: clamp(1.25rem, 4vw, 2rem);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        color: #ffffff;
    }

    .gfs-card {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        align-items: stretch;
        justify-content: stretch;
        gap: 1rem;

        margin: 2em auto;
        width: min(100%, 68rem);
        padding: clamp(1rem, 3vw, 1.4rem);

        background:
                linear-gradient(180deg, rgba(255, 255, 255, 0.92), rgba(255, 244, 206, 0.86)),
                #ffc100;
        border: 1px solid rgba(255, 255, 255, 0.58);
        border-radius: 0.5rem;

        box-shadow: 0 1rem 2.4rem rgba(37, 49, 58, 0.18);
    }

    .gfs-header {
        display: flex;
        align-items: center;
        gap: 0.75em;
        margin-bottom: 0;
        color: var(--ink);
        font-size: clamp(1.25rem, 3vw, 2rem);

        @media screen and (max-width: 768px) {
            font-size: 1.5em;
        }
    }

    .gfs-icon {
        width: 2.2em;
        height: 2.2em;
        border-radius: 0.75em;

        display: grid;
        place-items: center;

        background: rgba(0, 0, 0, 0.18);
        font-size: 1.1em;
    }

    .gfs-text h3 {
        margin: 0;
        font-size: 1em;
        overflow-wrap: anywhere;
    }

    .gfs-text p {
        font-family: sans-serif;
        margin: 0.25em 0 0;
        font-size: 0.75em;
        color: var(--muted-ink);
        opacity: 1;
    }

    .gfs-actions {
        display: flex;
        align-items: center;
        justify-content: center;
        flex-wrap: wrap;
        gap: 0.6em;

    }

    @media screen and (max-width: 768px) {
        .gfs-card {
            grid-template-columns: 1fr;
            width: min(100%, 22rem);
        }

        .gfs-actions {
            justify-content: flex-start;
        }

        .gfs-actions .button {
            width: 100%;
        }
    }
</style>
