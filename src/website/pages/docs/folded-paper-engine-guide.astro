---
import GuideLayout from "../../layouts/GuideLayout.astro";
---
<GuideLayout title="Engine Guide">
    <section
            class="web-splash"
    >
        <div
                class="web-splash-inner base-background"
        >
            <img class="web-splash-img" src="/assets/images/guide-splash.png" alt="Folded Paper Engine docs owl">
        </div>
    </section>
    <section
            class="section top-section"
    >
        <header>
            <div
                    class="section-title"
            >
                Engine Guide
                <div class="section-subtitle">
                    Blender → Godot workflows, behaviors, and runtime reference
                </div>
            </div>
        </header>
        <div class="section-body doc-tiles">
            <div class="doc-grid">
                <a class="doc-card" href="/docs/fpe-scene-settings.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/scene-settings.png');">
                        Scene Settings
                    </div>
                    <div class="doc-card-body">Sky color, gravity overrides, music, and scene-level events.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-characters-players-and-cameras.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/characters.png');">
                        Characters, Players and Cameras
                    </div>
                    <div class="doc-card-body">Player rigs, NPCs and camera behavior.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-animation-and-events.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/animation.png');">
                        Animation and Frame Events
                    </div>
                    <div class="doc-card-body">Animation imports, frame-timed events, and playback control.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-audio.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/audio.png');">
                        Audio
                    </div>
                    <div class="doc-card-body">Speakers, autoplay, looping, and background music playlists.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-triggers-commands.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/triggers.png');">
                        Triggers and Commands
                    </div>
                    <div class="doc-card-body">Areas, trigger filters, command catalog, and automation.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-inventory-and-holdables.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/inventory.png');">
                        Inventory and Holdables
                    </div>
                    <div class="doc-card-body">Inventory kinds, stack sizes, and hand-held items.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-conversations.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/conversations.png');">
                        Conversations (Advanced)
                    </div>
                    <div class="doc-card-body">Dialogue authoring and reply selection.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-ui.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/ui-elements.png');">
                        UI and Cursors
                    </div>
                    <div class="doc-card-body">UI Elements, menu flow and overlays.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-input.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/input.png');">
                        Input (Advanced)
                    </div>
                    <div class="doc-card-body">Action maps and controller support.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-cameras.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/cameras.png');">
                        Cameras
                    </div>
                    <div class="doc-card-body">Player camera settings, switching, and best practices.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-subscenes-and-levels.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/sub-scene.png');">
                        Sub Scenes and Level Loading
                    </div>
                    <div class="doc-card-body">Friendly recipes for doors, hubs, and streamed interiors.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-troubleshooting.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/troubleshooting.png');">
                        Troubleshooting
                    </div>
                    <div class="doc-card-body">Common pipeline issues and fixes.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-physics-and-colliders.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/physics.png');">
                        Physics and Colliders (Technical)
                    </div>
                    <div class="doc-card-body">Rigid bodies, collider generation, holdable bodies, and movement.</div>
                </a>
                <a class="doc-card" href="/docs/fpe-pipeline.html">
                    <div class="doc-card-title"
                         style="background-image: url('/docs/thumbs/pipeline.png');">
                        Pipeline and Runtime (Technical)
                    </div>
                    <div class="doc-card-body">GLB import flow, load/unload lifecycle, and feature registration.</div>
                </a>
            </div>
        </div>
    </section>
</GuideLayout>
