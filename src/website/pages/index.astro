---
import SiteLayout from "../layouts/SiteLayout.astro";
import FeaturedOnGameFromScratch from "../components/index/FeaturedOnGameFromScratch.astro";

const supportUrls = {
    kofiHome: "https://ko-fi.com/papercraftgames?utm_source=fpe_site&utm_medium=home_support_section&utm_campaign=fpe_support",
    githubHome: "https://github.com/sponsors/papercraftgames?utm_source=fpe_site&utm_medium=home_support_section&utm_campaign=fpe_support",
    kofiDownload: "https://ko-fi.com/papercraftgames?utm_source=fpe_site&utm_medium=download_section&utm_campaign=fpe_support",
    githubDownload: "https://github.com/sponsors/papercraftgames?utm_source=fpe_site&utm_medium=download_section&utm_campaign=fpe_support",
};
---

<SiteLayout
        title="Instant Game Mechanics from Blender to Godot"
        description="Folded Paper Engine creates instant game mechanics from Blender to Godot. Tag players, triggers, physics, audio, inventory items, scene metadata, and animation events in Blender, then export playable Godot scenes."
>
    <section class="home-hero" aria-labelledby="home-hero-title">
        <div class="home-hero-copy">
            <p class="eyebrow">Instant Game Mechanics from Blender to Godot</p>
            <h2 id="home-hero-title">Folded Paper Engine</h2>
            <p class="hero-lede">
                Tag gameplay in Blender, export standard GLTF, and open playable Godot scenes with players, triggers,
                speakers, inventory items, scene metadata, animation events, and more.
            </p>
            <div class="hero-actions" aria-label="Primary actions">
                <a class="button blue blender-download"
                   href="https://github.com/papercraftgames/folded-paper-engine/releases/latest/download/folded_paper_engine_blender.zip">
                    Download for Blender 4.4+
                    <img class="button-icon" src="/assets/images/blender-logo-icon.png" alt="">
                </a>
                <a class="button godot-download"
                   href="https://github.com/papercraftgames/folded-paper-engine/releases/latest/download/folded_paper_engine_godot.zip">
                    Download for Godot 4.4+
                    <img class="button-icon" src="/assets/images/godot-logo-icon.png" alt="">
                </a>
            </div>
            <div class="hero-links" aria-label="Documentation shortcuts">
                <a href="/docs/folded-paper-engine-guide.html">Engine guide</a>
                <a href="/blender-panel-docs.html">Blender panels</a>
                <a href="/godot-feature-docs.html">Godot features</a>
            </div>
        </div>

        <div class="hero-stage">
            <div class="web-splash">
                <div class="web-splash-inner base-background">
                    <img class="web-splash-img index-web-splash" src="/assets/images/web-splash.png" alt="Folded Paper Engine demo scene preview">
                    <img class="apple-sticker" src="/assets/images/apple-sticker.png" alt="">
                    <img class="star-sticker" src="/assets/images/splash-star.png" alt="">
                    <a class="demo-button button red" href="/demo.html">
                        Play the Demo
                        <img class="button-icon" src="/assets/images/mug-icon.png" alt="">
                    </a>
                </div>
            </div>
        </div>
    </section>
    <FeaturedOnGameFromScratch/>

    <section class="home-section support-section" aria-labelledby="support-title">
        <div class="support-card">
            <div class="section-heading support-heading">
                <img src="/assets/images/mug-icon.png" alt="">
                <div>
                    <p class="eyebrow">Fund ongoing FPE development</p>
                    <h2 id="support-title">Help Keep FPE Free</h2>
                </div>
            </div>
            <p class="support-card-body">
                Folded Paper Engine stays free, open-source, and MIT licensed. Support helps fund ongoing maintenance,
                docs, tutorials, sample projects, and the first official showcase game.
                Support helps keep instant Blender-to-Godot game mechanics free, maintained, documented, and backed by
                real showcase projects.
            </p>
            <div class="support-actions">
                <a class="button gold" href={supportUrls.kofiHome} target="_blank" rel="noopener noreferrer">
                    Support FPE
                    <img class="button-icon" src="/assets/images/mug-icon.png" alt="">
                </a>
                <a class="button blue" href={supportUrls.githubHome} target="_blank" rel="noopener noreferrer">
                    Sponsor on GitHub
                    <img class="button-icon" src="/assets/images/github-logo.png" alt="">
                </a>
            </div>
            <p class="support-note">
                Ko-fi is the easiest way to support FPE. GitHub Sponsors is available for open-source/dev-focused support.
            </p>
        </div>
    </section>

    <section class="home-section docs-hub" aria-labelledby="docs-title">
        <div class="section-heading">
            <img src="/assets/images/doc-owl.png" alt="">
            <div>
                <p class="eyebrow">Learn the toolchain</p>
                <h2 id="docs-title">Start where you work</h2>
            </div>
        </div>
        <div class="doc-grid">
            <a class="doc-card" href="/blender-panel-docs.html">
                <img src="/assets/images/blender-logo-icon.png" alt="">
                <span>Blender Panels</span>
                <small>Author gameplay metadata where your level already lives.</small>
            </a>
            <a class="doc-card" href="/godot-feature-docs.html">
                <img src="/assets/images/godot-logo-icon.png" alt="">
                <span>Godot Features</span>
                <small>See how imported scene data becomes runtime behavior.</small>
            </a>
            <a class="doc-card" href="/godot-api-docs.html">
                <img src="/assets/images/guide-icon.png" alt="">
                <span>Godot API</span>
                <small>Reference the scripts and extension points behind FPE.</small>
            </a>
            <a class="doc-card" href="/youtube-tutorials.html">
                <img src="/assets/images/youtube-logo-small.png" alt="">
                <span>Tutorials</span>
                <small>Follow guided videos for practical Blender-to-Godot workflows.</small>
            </a>
        </div>
    </section>

    <section class="home-section workflow-section" aria-labelledby="workflow-title">
        <div class="section-heading">
            <div>
                <p class="eyebrow">A standard export, made smarter</p>
                <h2 id="workflow-title">Three steps from scene art to playable setup</h2>
            </div>
        </div>
        <div class="workflow-steps">
            <article>
                <span>01</span>
                <h3>Tag objects in Blender</h3>
                <p>Use FPE panels to mark Players, Triggers, Speakers, Holdable Items, and scene settings.</p>
            </article>
            <article>
                <span>02</span>
                <h3>Export standard GLTF</h3>
                <p>FPE carries custom properties through Blender's existing GLTF pipeline without a custom format.</p>
            </article>
            <article>
                <span>03</span>
                <h3>Import to Godot</h3>
                <p>Add the FoldedPaperEngine node and let the addon enhance imported nodes with the behaviors you tagged.</p>
            </article>
        </div>
    </section>

    <section id="instant-game-mechanics" class="home-section mechanics-section" aria-labelledby="mechanics-title">
        <div class="mechanics-copy">
            <p class="eyebrow">Blender scene data, Godot runtime behavior</p>
            <h2 id="mechanics-title">Instant game mechanics from Blender-authored scenes</h2>
            <p>
                Folded Paper Engine turns Blender-authored scene metadata into Godot game mechanics. Use Blender panels
                to tag players, triggers, physics objects, speakers, inventory items, scene transitions, animation
                events, and other gameplay behavior. Export standard GLTF, then let the Godot addon load the scene and
                wire the runtime behavior.
            </p>
            <p>
                The goal is not to replace Godot development. FPE removes repetitive setup so artists, designers, and
                programmers can iterate on playable scenes faster.
            </p>
            <p>
                Because the data travels through standard GLTF custom properties, the same GLTF gameplay metadata can
                support Blender to Godot game mechanics, quick Godot gameplay prototyping, and later custom runtime
                scripts.
            </p>
            <nav class="mechanics-links" aria-label="Learn more about Folded Paper Engine mechanics">
                <a href="/blender-panel-docs.html">Blender game logic panels</a>
                <a href="/godot-feature-docs.html">Godot gameplay features</a>
                <a href="/youtube-tutorials.html">Blender to Godot tutorials</a>
                <a href="/demo.html">Playable demo</a>
            </nav>
        </div>
    </section>

    <section class="home-section feature-section" aria-labelledby="feature-title">
        <div class="section-heading">
            <div>
                <p class="eyebrow">Built for repeated level work</p>
                <h2 id="feature-title">Less boilerplate between your scene and your game</h2>
            </div>
        </div>
        <div class="feature-grid">
            <article>
                <h3>Characters & Players</h3>
                <p>Configure rigs, NPCs, camera behavior, and player-facing metadata directly on scene objects.</p>
            </article>
            <article>
                <h3>Triggers & Events</h3>
                <p>Define area triggers, command catalogs, scene events, and animation frame events in the authoring file.</p>
            </article>
            <article>
                <h3>Physics & Interaction</h3>
                <p>Mark holdable items, inventory objects, rigid bodies, and collider behavior before export.</p>
            </article>
            <article>
                <h3>Scene Management</h3>
                <p>Carry sky color, sub-scenes, loading behavior, UI elements, and scene metadata into Godot.</p>
            </article>
            <article>
                <h3>Audio</h3>
                <p>Set up music imports, looping, autoplay, background tracks, and speakers as part of level authoring.</p>
            </article>
            <article>
                <h3>Escape Hatches</h3>
                <p>Override generated behavior, add custom scripts, or extend FPE's modular runtime when a scene needs more.</p>
            </article>
        </div>
    </section>

    <section class="home-section audience-section" aria-labelledby="audience-title">
        <div class="audience-copy">
            <p class="eyebrow">For artists, designers, solo developers, and teams</p>
            <h2 id="audience-title">Prototype faster without locking programmers out</h2>
            <p>
                Artists can build interactive scenes without touching code. Programmers can rely on FPE for repetitive
                setup, then customize the unique parts. Teams get a cleaner handoff from Blender-authored levels to the
                Godot runtime.
            </p>
        </div>
        <img src="/assets/images/guide-splash.png" alt="Folded Paper Engine guide artwork">
    </section>

    <section id="download" class="home-section download-section" aria-labelledby="download-title">
        <img src="/assets/images/dl-backpack.png" alt="">
        <div>
            <p class="eyebrow">Pack for your adventure</p>
            <h2 id="download-title">Download Folded Paper Engine</h2>
            <p>Install both sides of the workflow: Blender authoring panels and the Godot runtime addon.</p>
        </div>
        <div class="download-actions">
            <a class="button blue blender-download"
               href="https://github.com/papercraftgames/folded-paper-engine/releases/latest/download/folded_paper_engine_blender.zip">
                Download for Blender 4.4+
                <img class="button-icon" src="/assets/images/blender-logo-icon.png" alt="">
            </a>
            <a class="button blue godot-download"
               href="https://github.com/papercraftgames/folded-paper-engine/releases/latest/download/folded_paper_engine_godot.zip">
                Download for Godot 4.4+
                <img class="button-icon" src="/assets/images/godot-logo-icon.png" alt="">
            </a>
            <a class="previous-versions"
               href="https://github.com/papercraftgames/folded-paper-engine/releases"
               target="_blank"
               rel="noopener noreferrer">
                Previous versions
            </a>
        </div>
        <aside class="download-support-card" aria-label="Support Folded Paper Engine">
            <p>FPE is free. Support keeps it maintained.</p>
            <div class="download-support-actions">
                <a class="button gold medium" href={supportUrls.kofiDownload} target="_blank" rel="noopener noreferrer">
                    <img class="button-icon" src="/assets/images/mug-icon.png" alt="">
                    Support FPE
                </a>
                <a class="button blue medium" href={supportUrls.githubDownload} target="_blank" rel="noopener noreferrer">
                    <img class="button-icon" src="/assets/images/github-logo.png" alt="">
                    Sponsor on GitHub
                </a>
            </div>
        </aside>
    </section>
</SiteLayout>
