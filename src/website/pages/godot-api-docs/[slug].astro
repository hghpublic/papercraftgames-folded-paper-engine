---
import GodotApiLayout from "../../layouts/GodotAPILayout.astro";
import {loadGodotApiPages, type GodotApiPage} from "../../godotApiDocs";

export async function getStaticPaths() {
  const pages = await loadGodotApiPages();
  return pages.map((p) => ({
    params: {slug: p.slug},
    props: {page: p},
  }));
}

const {page} = Astro.props as { page: GodotApiPage };
const pageDescription =
  page.summary && page.summary.trim().length >= 40
    ? page.summary
    : `Reference documentation for ${page.title} in the Folded Paper Engine Godot addon API, including class details, methods, properties, signals, and constants.`;
---

<GodotApiLayout
    title={page.title}
    description={pageDescription}
    image="/assets/images/godot-feature-splash.png"
>
    <article class="api-doc-article">
        <div class="api-doc-body" set:html={page.bodyHtml}/>
    </article>
</GodotApiLayout>
