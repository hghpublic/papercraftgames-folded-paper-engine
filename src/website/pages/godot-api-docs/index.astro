---
import GodotApiLayout from "../../layouts/GodotAPILayout.astro";
import {loadGodotApiPages} from "../../godotApiDocs";

const pages = await loadGodotApiPages();

// Light-weight search index we can embed into the page as JSON
const searchIndex = pages
  .filter(p => !p.isBasicFile)
  .map((p) => ({
    slug: p.slug,
    title: p.title,
    summary: p.summary,
  }));
// Build the browser script as a string, with searchIndex baked in
const searchScript = `
const index = ${JSON.stringify(searchIndex)};
const input = document.getElementById("api-search-input");
const list  = document.getElementById("api-search-results");

if (input && list) {
  input.addEventListener("input", () => {
    const query = input.value.toLowerCase().trim();
    const items = Array.from(list.querySelectorAll("a"));

    if (query === "") {
      items.forEach((a) => {
        a.style.display = "";
      });
    } else {
      items.forEach((a) => {
        const text = (a.textContent || "").toLowerCase();
        a.style.display = text.includes(query) ? "" : "none";
      });
    }
  });
}
`;
---

<GodotApiLayout
        title="Godot API for Blender-to-Godot Game Mechanics"
        description="Browse the Folded Paper Engine Godot API for loading Blender-authored GLTF scenes, reading gameplay metadata, and wiring instant game mechanics at runtime."
        hideSubTitle
>
    <section class="api-index">
        <p>
            This API supports the Godot runtime side of Folded Paper Engine's Blender-to-Godot game mechanics pipeline.
        </p>
        <div class="api-search">
            <input id="api-search-input" class="api-input" type="search" placeholder="Search API Docs…"/>
        </div>
        <br/>
        <div id="api-search-results" class="api-index-list">
          {searchIndex.map((p) => (
                  <a href={`/godot-api-docs/${p.slug}.html`}>
                      <code>{p.title}</code>
                  </a>
          ))}
        </div>
    </section>

    <script is:inline set:html={searchScript}></script>
</GodotApiLayout>
