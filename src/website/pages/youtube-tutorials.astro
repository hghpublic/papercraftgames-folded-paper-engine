---
import TutorialPlaylistGrid from "../components/TutorialPlaylistGrid";
import GuideLayout from "../layouts/GuideLayout.astro";
---

<GuideLayout
        title="Blender to Godot Game Mechanics Tutorials"
        description="Watch Folded Paper Engine tutorials for creating game mechanics from Blender to Godot, including gameplay tagging, triggers, runtime features, level setup, and playable scene prototyping."
        hideGuideIndexBreadcrumb
>
    <section class="web-splash">
        <div class="web-splash-inner video-box">
            <iframe
                    id="tutorial-player"
                    width="100%"
                    height="720"
                    src="https://www.youtube.com/embed/videoseries?list=PLM1XlwxBilobr6XVs-7H6O_mMXAiHZEcz"
                    title="YouTube playlist player"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen>
            </iframe>
        </div>
    </section>

    <section class="section top-section">
        <header>
            <div class="section-title">
                Tutorials
                <div class="section-subtitle">
                    Blender → Godot workflows, behaviors, and runtime reference videos
                </div>
            </div>
        </header>

        <p class="tutorial-intro">
            These tutorials show how to tag gameplay in Blender and test playable Godot scenes with instant game
            mechanics.
        </p>

        <!-- Hydrated React component -->
        <TutorialPlaylistGrid
                client:load
                iframeId="tutorial-player"
        />
    </section>
</GuideLayout>
