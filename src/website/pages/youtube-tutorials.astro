---
import TutorialPlaylistGrid from "../components/TutorialPlaylistGrid";
import GuideLayout from "../layouts/GuideLayout.astro";
---

<GuideLayout title="YouTube Tutorials" hideGuideIndexBreadcrumb>
    <section class="web-splash">
        <div class="web-splash-inner video-box">
            <iframe
                    id="tutorial-player"
                    width="100%"
                    height="720"
                    src="https://www.youtube.com/embed/videoseries?list=PLM1XlwxBilobr6XVs-7H6O_mMXAiHZEcz"
                    title="YouTube playlist player"
                    frameborder="0"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                    allowfullscreen>
            </iframe>
        </div>
    </section>

    <section class="section top-section">
        <header>
            <div class="section-title">
                Tutorials
                <div class="section-subtitle">
                    Blender → Godot workflows, behaviors, and runtime reference videos
                </div>
            </div>
        </header>

        <!-- Hydrated React component -->
        <TutorialPlaylistGrid
                client:load
                iframeId="tutorial-player"
        />
    </section>
</GuideLayout>
