---
import SiteLayout from "./SiteLayout.astro";

const {title} = Astro.props;
const apiIndexLabel = "Godot Addon API Docs";
const isApiIndex =
  Astro.url.pathname === "/godot-api-docs" ||
  Astro.url.pathname === "/godot-api-docs.html";
const showCurrentApiCrumb = title && title !== apiIndexLabel;
---

<SiteLayout {...Astro.props} title={title}>
    <Fragment slot="head">
        <link rel="stylesheet" href="/assets/css/docs.css"/>
        <link rel="stylesheet" href="/assets/css/api-docs.css"/>
        <slot name="head"/>
    </Fragment>

    <nav class="section section-breadcrumbs" aria-label="Breadcrumb">
        <a href="/">Home</a>
        <span>/</span>
        {isApiIndex ? (
            <span aria-current="page">{apiIndexLabel}</span>
        ) : (
            <a href="/godot-api-docs">Godot API Docs</a>
        )}
        {showCurrentApiCrumb && (
            <>
                <span>/</span>
                <span aria-current="page">{title}</span>
            </>
        )}
    </nav>

    <section class="web-splash">
        <div class="web-splash-inner base-background">
            <img
                    class="web-splash-img"
                    src="/assets/images/godot-feature-splash.png"
                    alt="Godot Feature Splash"
            />
        </div>
    </section>

    <section class="section top-section">
        <header>
            <div class="section-title">
                Godot Addon API Docs
            </div>
        </header>
    </section>

    <section class="section content-section">
      {title && (
              <header>
                  <h1 class="section-title">
                    {title}
                  </h1>
              </header>
      )}
        <main>
            <slot/>
        </main>
    </section>
</SiteLayout>
