---
import {
  buildStructuredData,
  getDefaultOgImagePath,
  getPageSeo,
  getPageTitle,
  getSiteName,
} from "../seo";

const {
  title = "Folded Paper Engine",
  description,
  image,
  pageHeading,
  robots = "index, follow, max-image-preview:large",
  structuredData = [],
} = Astro.props;

const mappedSeo = getPageSeo(Astro.url.pathname);
const siteName = getSiteName();
const canonicalUrl = new URL(Astro.url.pathname, Astro.site);
const canonical = canonicalUrl.toString().replace(/\/$/, "");
const pageDescription =
  description ??
  mappedSeo?.description ??
  "Folded Paper Engine is a Blender-to-Godot addon that streamlines gameplay setup, level authoring, and GLTF import workflows.";
const socialImagePath = image ?? mappedSeo?.image ?? getDefaultOgImagePath();
const socialImageUrl = new URL(socialImagePath, Astro.site).toString();
const documentTitle = getPageTitle(Astro.url.pathname, title);
const primaryHeading =
  pageHeading ?? mappedSeo?.heading ?? (Astro.url.pathname === "/" ? siteName : title);
const jsonLd = buildStructuredData({
  pathname: Astro.url.pathname,
  title: primaryHeading,
  description: pageDescription,
  canonical,
  imageUrl: socialImageUrl,
}).concat(structuredData);
const supportUrls = {
  kofiHeader: "https://ko-fi.com/papercraftgames?utm_source=fpe_site&utm_medium=header&utm_campaign=fpe_support",
  kofiFooter: "https://ko-fi.com/papercraftgames?utm_source=fpe_site&utm_medium=footer&utm_campaign=fpe_support",
  githubFooter: "https://github.com/sponsors/papercraftgames?utm_source=fpe_site&utm_medium=footer&utm_campaign=fpe_support",
  repo: "https://github.com/papercraftgames/folded-paper-engine",
};
---

<html lang="en">
<head>
    <!-- Google tag (gtag.js) -->
    <script async src="https://www.googletagmanager.com/gtag/js?id=G-QM9RJ9QDWL"></script>
    <script type="application/javascript">
      window.dataLayer = window.dataLayer || [];

      function gtag() {
        dataLayer.push(arguments);
      }

      gtag('js', new Date());
      gtag('config', 'G-QM9RJ9QDWL');

      document.addEventListener("DOMContentLoaded", () => {
        document.querySelectorAll(".pickle-box img").forEach((p, i) => {
          p.addEventListener("mouseenter", () => {
            gtag('event', 'pickle_hover', {
              pickle_index: i + 1
            });
          });
        });

        document.querySelectorAll(".blender-download").forEach((blenderDownloadButton) => {
          blenderDownloadButton.addEventListener("click", () => {
            gtag('event', 'download_blender', {
              event_category: 'download',
              event_label: 'blender_plugin'
            });
          });
        });

        document.querySelectorAll(".godot-download").forEach((godotDownloadButton) => {
          godotDownloadButton.addEventListener("click", () => {
            gtag('event', 'download_godot', {
              event_category: 'download',
              event_label: 'godot_plugin'
            });
          });
        });
      });
    </script>

    <meta charset="utf-8"/>
    <meta http-equiv="X-UA-Compatible" content="IE=edge"/>
    <meta
            name="viewport"
            content="width=device-width, initial-scale=1, maximum-scale=1"
    />
    <meta name="description" content={pageDescription}/>
    <meta name="robots" content={robots}/>
    <meta name="author" content="Papercraft Games"/>
    <meta property="og:site_name" content={siteName}/>
    <meta property="og:type" content="website"/>
    <meta property="og:title" content={documentTitle}/>
    <meta property="og:description" content={pageDescription}/>
    <meta property="og:url" content={canonical}/>
    <meta property="og:image" content={socialImageUrl}/>
    <meta property="og:image:alt" content={primaryHeading}/>
    <meta name="twitter:card" content="summary_large_image"/>
    <meta name="twitter:title" content={documentTitle}/>
    <meta name="twitter:description" content={pageDescription}/>
    <meta name="twitter:image" content={socialImageUrl}/>
    <title>{documentTitle}</title>

    <link rel="canonical" href={canonical}>
    <link rel="sitemap" href="/sitemap-index.xml"/>
    <link rel="icon" type="image/png" href="/icons/favicon-96x96.png" sizes="96x96"/>
    <link rel="icon" type="image/svg+xml" href="/icons/favicon.svg"/>
    <link rel="shortcut icon" href="/icons/favicon.ico"/>
    <link rel="apple-touch-icon" sizes="180x180" href="/icons/apple-touch-icon.png"/>
    <meta name="apple-mobile-web-app-title" content="Folded Paper Engine"/>
    <link rel="manifest" href="/icons/site.webmanifest"/>
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)}/>

    <link rel="stylesheet" href="/assets/css/index.css"/>

    <slot name="head"/>
</head>

<body>
<header class="header">
    <a href="/">
        <img class="logo" src="/assets/images/logo.png" alt="Folded Paper Engine logo"/>
    </a>
    <nav class="header-nav" aria-label="Primary navigation">
        <a href="/docs/folded-paper-engine-guide.html">Guide</a>
        <a href="/blender-panel-docs.html">Blender</a>
        <a href="/godot-feature-docs.html">Godot</a>
        <a href="/godot-api-docs.html">API</a>
        <a href="/youtube-tutorials.html">Tutorials</a>
    </nav>
    <div class="spacer"></div>
    <a class="button" href="/#download">
        Download
        <img class="dl-icon" src="/assets/images/dl-icon.png" alt="Download"/>
    </a>
    <a
            class="button gold header-support-button"
            href={supportUrls.kofiHeader}
            target="_blank"
            rel="noopener noreferrer"
    >
        Support FPE
        <img class="button-icon" src="/assets/images/mug-icon.png" alt=""/>
    </a>
</header>

<main>
    <h1 style="position:absolute;width:1px;height:1px;padding:0;margin:-1px;overflow:hidden;clip:rect(0, 0, 0, 0);white-space:nowrap;border:0;">
      {primaryHeading}
    </h1>
    <slot/>
</main>

<footer class="footer">
    <a href="https://papercraft.games" target="_blank" rel="noopener noreferrer">
        <img
                class="papercraft-logo"
                src="/assets/images/papercraft-games-logo.png"
                alt="Papercraft Games"
        />
    </a>

    <nav class="footer-nav" aria-label="Explore Folded Paper Engine">
        <a href="/">Home</a>
        <a href="/blender-panel-docs.html">Blender Panels</a>
        <a href="/godot-feature-docs.html">Godot Features</a>
        <a href="/godot-api-docs.html">Godot API Docs</a>
        <a href="/docs/folded-paper-engine-guide.html">Engine Guide</a>
        <a href="/youtube-tutorials.html">Tutorials</a>
    </nav>

    <nav class="footer-nav footer-concepts" aria-label="Core Concepts">
        <a href="/#instant-game-mechanics">Instant Game Mechanics</a>
        <a href="/blender-panel-docs.html">Blender Game Logic Panels</a>
        <a href="/godot-feature-docs.html">Godot Game Mechanics</a>
        <a href="/youtube-tutorials.html">Blender to Godot Tutorials</a>
        <a href="/demo.html">Playable Demo</a>
    </nav>

    <section class="footer-support" aria-labelledby="footer-support-title">
        <h2 id="footer-support-title">Support Folded Paper Engine</h2>
        <p>Using FPE? Support ongoing development, documentation, and showcase projects.</p>
        <div class="footer-support-links">
            <a class="button gold medium" href={supportUrls.kofiFooter} target="_blank" rel="noopener noreferrer">
                <img class="button-icon" src="/assets/images/mug-icon.png" alt=""/>
                Ko-fi
            </a>
            <a class="button blue medium" href={supportUrls.githubFooter} target="_blank" rel="noopener noreferrer">
                <img class="button-icon" src="/assets/images/github-logo.png" alt=""/>
                GitHub Sponsors
            </a>
            <a class="footer-support-text-link" href={supportUrls.repo} target="_blank" rel="noopener noreferrer">
                GitHub Repo
            </a>
        </div>
    </section>

    <div class="social">
        <a href={supportUrls.repo} target="_blank" rel="noopener noreferrer">
            <img src="/assets/images/github-logo.png" alt="GitHub"/>
        </a>
        <a href="https://www.youtube.com/@PapercraftGamesOfficial" target="_blank" rel="noopener noreferrer">
            <img src="/assets/images/youtube-logo.png" alt="YouTube"/>
        </a>
        <a href="https://bsky.app/profile/papercraftgames.bsky.social" target="_blank" rel="noopener noreferrer">
            <img src="/assets/images/bluesky-logo.png" alt="Bluesky"/>
        </a>
        <a href="https://www.facebook.com/profile.php?id=61584265860990" target="_blank" rel="noopener noreferrer">
            <img src="/assets/images/facebook-logo.png" alt="Facebook"/>
        </a>
        <a href="https://www.reddit.com/user/papercraftgames" target="_blank" rel="noopener noreferrer">
            <img src="/assets/images/reddit-logo.png" alt="Reddit"/>
        </a>
        <a href="https://discord.gg/gdGk2tBevz" target="_blank" rel="noopener noreferrer">
            <img src="/assets/images/discord-logo.png" alt="Discord"/>
        </a>
        <a href="https://papercraft-games.itch.io/folded-paper-engine" target="_blank" rel="noopener noreferrer">
            <img src="/assets/images/itch-io-logo.png" alt="Itch.io"/>
        </a>
    </div>
</footer>

<footer class="pickle-footer">
    <div>© {new Date().getFullYear()} Folded Paper Engine. All rights reserved.</div>
    <a
            class="button gold medium"
            href={supportUrls.kofiFooter}
            target="_blank"
            rel="noopener noreferrer"
    >
        <img class="sponsor-icon" src="/assets/images/mug-icon.png" alt=""/>
        Support FPE
    </a>
    <div class="pickle-box">
        <img src="/assets/images/pickle-icon.png" alt="A green pickle"/>
        <img src="/assets/images/pickle-icon.png" alt="A green pickle"/>
        <img src="/assets/images/pickle-icon.png" alt="A green pickle"/>
        <img src="/assets/images/pickle-icon.png" alt="A green pickle"/>
        <img src="/assets/images/pickle-icon.png" alt="A green pickle"/>
    </div>
</footer>
<script is:inline src="/support-widget.js"></script>
</body>
</html>
